<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="15.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <ItemGroup Label="ProjectConfigurations">
    <ProjectConfiguration Include="Debug|Win32">
      <Configuration>Debug</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
    <ProjectConfiguration Include="Release|Win32">
      <Configuration>Release</Configuration>
      <Platform>Win32</Platform>
    </ProjectConfiguration>
  </ItemGroup>
  <PropertyGroup Label="Globals">
    <VCProjectVersion>15.0</VCProjectVersion>
    <ProjectGuid>{A1B2C3D4-E5F6-7890-ABCD-EF1234567890}</ProjectGuid>
    <Keyword>Win32Proj</Keyword>
    <RootNamespace>cerf</RootNamespace>
    <WindowsTargetPlatformVersion>10.0</WindowsTargetPlatformVersion>
    <ConfigurationType>Application</ConfigurationType>
    <CharacterSet>Unicode</CharacterSet>
    <VcpkgEnableManifest>true</VcpkgEnableManifest>
    <VcpkgManifestRoot>$(SolutionDir)</VcpkgManifestRoot>
    <VcpkgTriplet>x86-windows-static</VcpkgTriplet>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.Default.props" />
  <!-- PlatformToolset is set to $(DefaultPlatformToolset) which Microsoft.Cpp.Default.props
       (imported above) populates with the installed-VS default: v143 on VS 2022 (CI
       runner), v145 on VS 2026 (maintainer's box). DO NOT hardcode v143/v145 here; it
       breaks whichever side doesn't have that toolset installed. Omitting PlatformToolset
       does NOT work either, because Microsoft.Cpp.props falls back to $(LegacyPlatformToolset)
       (v100, VS 2010) before $(DefaultPlatformToolset) when PlatformToolset is empty.
       CI can still override via /p:PlatformToolset=vNNN on the msbuild command line. -->
  <PropertyGroup Condition="'$(Configuration)'=='Debug'" Label="Configuration">
    <UseDebugLibraries>true</UseDebugLibraries>
    <PlatformToolset>$(DefaultPlatformToolset)</PlatformToolset>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)'=='Release'" Label="Configuration">
    <UseDebugLibraries>false</UseDebugLibraries>
    <PlatformToolset>$(DefaultPlatformToolset)</PlatformToolset>
  </PropertyGroup>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.props" />
  <ImportGroup Label="ExtensionSettings">
  </ImportGroup>
  <ImportGroup Label="Shared">
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <ImportGroup Label="PropertySheets" Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <Import Project="$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props" Condition="exists('$(UserRootDir)\Microsoft.Cpp.$(Platform).user.props')" Label="LocalAppDataPlatform" />
  </ImportGroup>
  <PropertyGroup Label="UserMacros" />
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <LinkIncremental>true</LinkIncremental>
    <OutDir>$(SolutionDir)\build\$(Configuration)\$(Platform)\</OutDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <LinkIncremental>false</LinkIncremental>
    <OutDir>$(SolutionDir)\build\$(Configuration)\$(Platform)\</OutDir>
  </PropertyGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Debug|Win32'">
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <Optimization>Disabled</Optimization>
      <PreprocessorDefinitions>_DEBUG;_CONSOLE;$(CerfExtraDefines);%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ConformanceMode>true</ConformanceMode>
      <RuntimeLibrary>MultiThreadedDebug</RuntimeLibrary>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalOptions>/utf-8 %(AdditionalOptions)</AdditionalOptions>
      <ObjectFileName>$(IntDir)%(RelativeDir)</ObjectFileName>
      <MultiProcessorCompilation>true</MultiProcessorCompilation>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <MinimumRequiredVersion>5.01</MinimumRequiredVersion>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalDependencies>$(YYThunksObj);kernel32.lib;user32.lib;gdi32.lib;shell32.lib;ole32.lib;comctl32.lib;advapi32.lib;comdlg32.lib;imm32.lib;winmm.lib;msimg32.lib;psapi.lib;dbghelp.lib;Ws2_32.lib;iphlpapi.lib;dwmapi.lib;gdiplus.lib;uxtheme.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Manifest>
      <AdditionalManifestFiles>cerf.manifest</AdditionalManifestFiles>
    </Manifest>
  </ItemDefinitionGroup>
  <ItemDefinitionGroup Condition="'$(Configuration)|$(Platform)'=='Release|Win32'">
    <ClCompile>
      <WarningLevel>Level4</WarningLevel>
      <TreatWarningAsError>true</TreatWarningAsError>
      <Optimization>MaxSpeed</Optimization>
      <FunctionLevelLinking>true</FunctionLevelLinking>
      <IntrinsicFunctions>true</IntrinsicFunctions>
      <PreprocessorDefinitions>NDEBUG;_CONSOLE;$(CerfExtraDefines);%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <ConformanceMode>true</ConformanceMode>
      <RuntimeLibrary>MultiThreaded</RuntimeLibrary>
      <LanguageStandard>stdcpp20</LanguageStandard>
      <AdditionalOptions>/FS /utf-8 %(AdditionalOptions)</AdditionalOptions>
      <ObjectFileName>$(IntDir)%(RelativeDir)</ObjectFileName>
    </ClCompile>
    <Link>
      <SubSystem>Console</SubSystem>
      <MinimumRequiredVersion>5.01</MinimumRequiredVersion>
      <EnableCOMDATFolding>true</EnableCOMDATFolding>
      <OptimizeReferences>true</OptimizeReferences>
      <GenerateDebugInformation>true</GenerateDebugInformation>
      <AdditionalDependencies>$(YYThunksObj);kernel32.lib;user32.lib;gdi32.lib;shell32.lib;ole32.lib;comctl32.lib;advapi32.lib;comdlg32.lib;imm32.lib;winmm.lib;msimg32.lib;psapi.lib;dbghelp.lib;Ws2_32.lib;iphlpapi.lib;dwmapi.lib;gdiplus.lib;uxtheme.lib;%(AdditionalDependencies)</AdditionalDependencies>
    </Link>
    <Manifest>
      <AdditionalManifestFiles>cerf.manifest</AdditionalManifestFiles>
    </Manifest>
  </ItemDefinitionGroup>
  <ItemGroup>
    <ClInclude Include="**\*.h" />
    <ClCompile Include="**\*.cpp" />
  </ItemGroup>
  <!-- YY-Thunks resolves every post-XP API import (SRW locks, condition
       variables, InitOnce, the thread pool, Fls*, GetTickCount64, dwmapi, ...)
       that the C++ standard library and the SDK headers pull in, by defining the
       __imp__* symbols itself: the linker binds them here, so no import-table
       entry is emitted and XP's loader is never asked for an export it lacks.
       Each stub GetProcAddress's the real API at runtime and falls back only
       when absent, so a single binary runs on XP through Windows 11.
       https://github.com/Chuyu-Team/YY-Thunks -->
  <PropertyGroup>
    <YYThunksVersion>v1.2.1</YYThunksVersion>
    <YYThunksDir>$(SolutionDir)third_party\yy_thunks\$(YYThunksVersion)</YYThunksDir>
    <YYThunksObj>$(YYThunksDir)\objs\x86\YY_Thunks_for_WinXP.obj</YYThunksObj>
  </PropertyGroup>
  <Target Name="RestoreYYThunks" BeforeTargets="ClCompile" Condition="!Exists('$(YYThunksObj)')">
    <Message Importance="high" Text="[BUILD] Downloading YY-Thunks $(YYThunksVersion) (XP compatibility thunks)..." />
    <DownloadFile SourceUrl="https://github.com/Chuyu-Team/YY-Thunks/releases/download/$(YYThunksVersion)/YY-Thunks-Objs.zip"
                  DestinationFolder="$(YYThunksDir)" />
    <Unzip SourceFiles="$(YYThunksDir)\YY-Thunks-Objs.zip" DestinationFolder="$(YYThunksDir)" />
    <Error Condition="!Exists('$(YYThunksObj)')" Text="YY-Thunks restore failed: $(YYThunksObj) not found after download." />
  </Target>
  <!-- Per-device trace files live in cerf/tracing/<device>/. The
       TraceManager framework at cerf/tracing/*.cpp stays always-built;
       per-device subdirectories are excluded in production mode, EXCEPT
       cerf/tracing/<device>/nkdbg/ which carries production NKDBG hooks
       (guest OS debug output) and is re-included. Passed by build.ps1 via
       /p:CerfMode=production. -->
  <ItemGroup Condition="'$(CerfMode)' == 'production'">
    <ClCompile Remove="tracing\*\**\*.cpp" />
    <ClCompile Include="tracing\*\nkdbg\*.cpp" />
  </ItemGroup>
  <ItemGroup>
    <ResourceCompile Include="cerf.rc" />
  </ItemGroup>
  <ItemGroup>
    <None Include="assets\cerf.ico" />
    <None Include="assets\uart_boot_bar.png" />
    <None Include="assets\oem\logo_compaq.png" />
    <None Include="assets\oem\logo_hp.png" />
    <None Include="assets\oem\logo_microsoft.png" />
    <None Include="assets\oem\logo_nec.png" />
    <None Include="assets\oem\logo_psc.png" />
    <None Include="assets\oem\logo_siemens.png" />
    <None Include="assets\oem\logo_ti.png" />
    <None Include="assets\oem\logo_zune.png" />
  </ItemGroup>
  <!-- Bundled device files — copied to devices/ next to cerf.exe.
       OverwriteReadOnlyFiles: source bundles once contained ROM-extracted
       files with ReadOnly+Hidden attrs; destination copies inherited them
       and then blocked every subsequent overwrite with ERROR_ACCESS_DENIED
       (CopyFile refuses to overwrite a read-only target). Even though the
       source bundle is now clean, stale read-only destinations still exist
       in build/ from older extractions — this flag clears their read-only
       bit before overwriting.
       Retries: files may be briefly locked by a running cerf.exe or by the
       host indexer — retry a few times before giving up on a single file. -->
  <Target Name="CopyBundledFiles" AfterTargets="Build">
    <ItemGroup>
      <BundledAllFiles Include="$(ProjectDir)..\bundled\**\*" Exclude="$(ProjectDir)..\bundled\**\.git;$(ProjectDir)..\bundled\**\*.i64;$(ProjectDir)..\bundled\**\*.id0;$(ProjectDir)..\bundled\**\*.id1;$(ProjectDir)..\bundled\**\*.id2;$(ProjectDir)..\bundled\**\*.nam;$(ProjectDir)..\bundled\**\*.til" />
      <BundledFiles Include="@(BundledAllFiles)" Exclude="$(ProjectDir)..\bundled\**\.gitkeep" />
    </ItemGroup>
    <MakeDir Directories="@(BundledAllFiles->'$(OutDir)%(RecursiveDir)')" />
    <Copy SourceFiles="@(BundledFiles)"
          DestinationFiles="@(BundledFiles->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')"
          SkipUnchangedFiles="true"
          OverwriteReadOnlyFiles="true"
          Retries="3"
          RetryDelayMilliseconds="200" />
  </Target>
  <Import Project="$(VCTargetsPath)\Microsoft.Cpp.targets" />
  <ImportGroup Label="ExtensionTargets">
  </ImportGroup>
</Project>
