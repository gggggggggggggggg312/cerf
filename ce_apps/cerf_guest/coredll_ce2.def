; By-name coredll imports for a CE 2.x MIPS cerf_guest body. Excludes the CRT /
; soft-FP / C++ runtime CE 2.0 coredll does not export by name; those come from
; the static CE 2.x libc.lib instead.

LIBRARY coredll.dll
EXPORTS
    ; MIPS soft-float emulation routines the compiler emits under -QMFPE; coredll
    ; exports them by name.
    __ll_mul
    __ll_rem
    __ll_lshift
    __ll_rshift
    __ll_bit
    __ll_to
    __ull_div
    __ull_rem
    __ull_rshift
    __ull_bit
