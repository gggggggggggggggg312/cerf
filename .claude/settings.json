{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/block_git_add_force.py",
            "if": "Bash(git *)",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash|PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/block_build_filter.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/block_pragma_lib.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/block_grab_bag_filename.py",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/autofix_em_dashes.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_cerf_file.py",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_checklist_edit.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_agent_docs_edit.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_bundled_device_edit.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_citation_verification.py",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_unfiltered_user_va_onpc.py",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_bash_drift.py",
            "if": "Bash(git *)",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "py -3 ${CLAUDE_PROJECT_DIR}/.claude/hooks/check_cerf_run_timeout.py",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
